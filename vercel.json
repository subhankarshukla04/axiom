{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["static/**", "templates/**", "*.py", "ml/**", "valuation/**", "*.json", "*.pkl"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DATABASE_TYPE": "sqlite",
    "FLASK_ENV": "development"
  }
}
